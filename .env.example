# Canonical origin of the live site (no trailing slash).
# Used for metadataBase, canonical/hreflang URLs, the sitemap, robots and OG images.
NEXT_PUBLIC_SITE_URL=https://laccaria.de

# ── Contact form SMTP ──────────────────────────────────────────────────────
# Server-side mail transport for the contact form (Nodemailer). Set these in
# .env.local with your provider's credentials — never commit real secrets.
SMTP_HOST=
SMTP_PORT=587
# `true` for implicit TLS (port 465); `false` for STARTTLS (port 587).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Where contact submissions are delivered, and the authenticated sender the
# mail is sent "from" (keep on your own domain so SPF/DMARC pass).
CONTACT_TO=johannes@laccaria.de
CONTACT_FROM=
